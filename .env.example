# ── Enrichment API keys (all free, ~2 min each to sign up) ─────────────

# https://api.census.gov/data/key_signup.html
CENSUS_KEY=

# https://newsapi.org/register
NEWSAPI_KEY=

# https://home.openweathermap.org/users/sign_up
OPENWEATHER_KEY=

# https://fred.stlouisfed.org/docs/api/api_key.html (optional — FRED works unauthenticated at low rate)
FRED_KEY=


# ── LLM email drafting (optional, template used if unset) ─────────────
#
# Point at any OpenAI compatible endpoint. Three vars, nothing else needed.
# Leave all three blank to use the deterministic template (no API cost).
#
# Examples:
#
#   Anthropic (claude-haiku-4-5, claude-sonnet-4-6, …):
#     LLM_BASE_URL=https://api.anthropic.com/v1
#     LLM_API_KEY=sk-ant-...
#     LLM_MODEL=claude-haiku-4-5-20251001
#
#   OpenAI:
#     LLM_BASE_URL=https://api.openai.com/v1
#     LLM_API_KEY=sk-...
#     LLM_MODEL=gpt-4o-mini
#
#   Groq:
#     LLM_BASE_URL=https://api.groq.com/openai/v1
#     LLM_API_KEY=gsk_...
#     LLM_MODEL=llama-3.3-70b-versatile
#
#   Fireworks.ai:
#     LLM_BASE_URL=https://api.fireworks.ai/inference/v1
#     LLM_API_KEY=fw_...
#     LLM_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
#
#   Together AI:
#     LLM_BASE_URL=https://api.together.xyz/v1
#     LLM_API_KEY=...
#     LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
#
#   Ollama (local, no key):
#     LLM_BASE_URL=http://localhost:11434/v1
#     LLM_API_KEY=
#     LLM_MODEL=llama3.1
#
#   Mistral / DeepSeek / vLLM / any other OpenAI compat endpoint:
#     LLM_BASE_URL=https://api.mistral.ai/v1
#     LLM_API_KEY=...
#     LLM_MODEL=mistral-large-latest

LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=


# ── Webhook (Google Sheets / CRM trigger) ─────────────────────────────
WEBHOOK_SECRET=
ALLOWED_ORIGINS=

# ── Misc ───────────────────────────────────────────────────────────────
PORT=8000
